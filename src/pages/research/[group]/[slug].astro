---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@layouts/Header.astro";
import Button from "@components/ui/Button.astro";
import Typography from "@components/ui/Typography.astro";
import {
  getContentPageModel,
  type ContentEntry,
  type ContentEntryMeta,
  type ContentGroup,
} from "@/content-engine";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import { ArrowLeft, ArrowRight, FlaskConical } from "lucide-astro";

type ResearchModule = {
  default: AstroComponentFactory;
  frontmatter: ContentEntryMeta;
};

interface Props {
  Content: AstroComponentFactory;
  meta: ContentEntryMeta;
  group: ContentGroup;
  sectionTitle: string;
  entryNumber: number;
  entryCount: number;
  prevEntry?: ContentEntry;
  nextEntry?: ContentEntry;
}

export function getStaticPaths() {
  const articleModules = import.meta.glob(
    "../../../../content/research/**/*.mdx",
    {
      eager: true,
    },
  ) as Record<string, ResearchModule>;

  const research = getContentPageModel("research");
  const groups = research.sections.flatMap(({ section, groups }) =>
    groups.map((groupModel) => ({
      groupModel,
      group: groupModel.group,
      sectionTitle: section.title,
    })),
  );

  return Object.entries(articleModules)
    .filter(([, module]) => !module.frontmatter.draft)
    .map(([path, module]) => {
      const fileSlug = path
        .replace("../../../../content/research/", "")
        .replace(/\.mdx$/, "")
        .replace(/\/index$/, "")
        .split("/")
        .at(-1);
      const groupData = groups.find(
        ({ group }) => group.id === module.frontmatter.groupId,
      );

      if (!module.frontmatter.groupId || !fileSlug || !groupData) {
        return null;
      }

      const entryIndex = groupData.groupModel.entries.findIndex(
        (entry) => entry.slug.split("/").at(-1) === fileSlug,
      );

      if (entryIndex < 0) {
        return null;
      }

      const prevEntry =
        entryIndex > 0
          ? groupData.groupModel.entries[entryIndex - 1]
          : undefined;
      const nextEntry =
        entryIndex >= 0 && entryIndex < groupData.groupModel.entries.length - 1
          ? groupData.groupModel.entries[entryIndex + 1]
          : undefined;

      return {
        params: {
          group: module.frontmatter.groupId,
          slug: fileSlug,
        },
        props: {
          Content: module.default,
          meta: module.frontmatter,
          group: groupData.group,
          sectionTitle: groupData.sectionTitle,
          entryNumber: entryIndex + 1,
          entryCount: groupData.groupModel.entries.length,
          prevEntry,
          nextEntry,
        },
      };
    })
    .filter((path): path is Exclude<typeof path, null> => path !== null);
}

const {
  Content,
  meta,
  group,
  sectionTitle,
  entryNumber,
  entryCount,
  prevEntry,
  nextEntry,
} = Astro.props;
const tags = meta.tags ?? [];
const prevSlug = prevEntry?.slug.split("/").at(-1);
const nextSlug = nextEntry?.slug.split("/").at(-1);
---

<BaseLayout title={`${meta.title} | Research`} description={meta.description}>
  <Header currentPath="/research" />

  <main class="brutal-page research-article-page">
    <article class="container research-article">
      <header class="research-article__header">
        <div class="research-article__copy">
          <Typography variant="kicker" as="span">
            <span class="home-hero__kicker-content">
              <FlaskConical class="home-hero__kicker-icon" aria-hidden="true" />
              research article
            </span>
          </Typography>

          <Typography variant="hero" as="h1" class="research-article__title">
            {meta.title}
          </Typography>

          <Typography variant="lead" as="p">
            {meta.description}
          </Typography>
        </div>

        <aside class="research-article__meta" aria-label="Данные материала">
          <span>Позиция</span>
          <strong>Запись №{entryNumber} из {entryCount}</strong>
          <span>Группа</span>
          <strong>{group.title}</strong>
          <span>Секция</span>
          <strong>{sectionTitle}</strong>

          {tags.length > 0 && <span>Теги</span>}

          {
            tags.length > 0 && (
              <ul>
                {tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            )
          }
        </aside>
      </header>

      <div class="research-article__back research-article__back--under-line">
        <Button href={`/research/${group.id}`}>
          <ArrowLeft class="button__icon" aria-hidden="true" />
          К группе
        </Button>

        <Button href="/research">
          <ArrowLeft class="button__icon" aria-hidden="true" />
          К исследованиям
        </Button>
      </div>

      <div class="research-article__content markdown-content">
        <Content />
      </div>

      <nav
        class="research-sequence-nav research-sequence-nav--bottom"
        aria-label="Навигация по записям после статьи"
      >
        {
          prevEntry && prevSlug ? (
            <a
              href={`/research/${group.id}/${prevSlug}`}
              class="research-sequence-nav__link"
            >
              <ArrowLeft aria-hidden="true" />
              <span>Запись №{entryNumber - 1}</span>
              <strong>{prevEntry.meta.title}</strong>
            </a>
          ) : (
            <span class="research-sequence-nav__link research-sequence-nav__link--disabled">
              <ArrowLeft aria-hidden="true" />
              <span>Начало группы</span>
              <strong>Предыдущей записи нет</strong>
            </span>
          )
        }

        <div class="research-sequence-nav__current">
          Запись №{entryNumber} из {entryCount}
        </div>

        {
          nextEntry && nextSlug ? (
            <a
              href={`/research/${group.id}/${nextSlug}`}
              class="research-sequence-nav__link research-sequence-nav__link--next"
            >
              <span>Запись №{entryNumber + 1}</span>
              <strong>{nextEntry.meta.title}</strong>
              <ArrowRight aria-hidden="true" />
            </a>
          ) : (
            <span class="research-sequence-nav__link research-sequence-nav__link--disabled research-sequence-nav__link--next">
              <span>Конец группы</span>
              <strong>Следующей записи нет</strong>
              <ArrowRight aria-hidden="true" />
            </span>
          )
        }
      </nav>
    </article>
  </main>
</BaseLayout>
