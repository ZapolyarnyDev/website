---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@layouts/Header.astro";
import Button from "@components/ui/Button.astro";
import Typography from "@components/ui/Typography.astro";
import { getContentPageModel, type ContentEntryKind } from "@/content-engine";
import { ArrowLeft, ArrowUpRight, FlaskConical } from "lucide-astro";

const research = getContentPageModel("research");
const pageDescription = "Полный архив исследовательских материалов.";
const kindLabels: Record<ContentEntryKind, string> = {
  article: "Статья",
  note: "Заметка",
  case: "Разбор",
  project: "Материал",
};
---

<BaseLayout
  title="Архив исследований | ZapolyarnyDev"
  description={pageDescription}
>
  <Header currentPath="/research" />

  <main class="brutal-page research-page">
    <div class="container research-shell">
      <section class="archive-hero" aria-labelledby="research-archive-title">
        <Typography variant="kicker" as="span">
          <span class="home-hero__kicker-content">
            <FlaskConical class="home-hero__kicker-icon" aria-hidden="true" />
            research archive
          </span>
        </Typography>

        <Typography variant="hero" as="h1" id="research-archive-title">
          Архив исследований
        </Typography>

        <Typography variant="lead" as="p">
          Все материалы исследований. Основная навигация всё ещё строится через
          группы, а архив нужен для быстрого поиска конкретного текста.
        </Typography>

        <div class="archive-hero__actions">
          <Button href="/research">
            <ArrowLeft class="button__icon" aria-hidden="true" />
            К исследованиям
          </Button>
        </div>
      </section>

      {
        research.sections.map(({ section, groups }) => (
          <section
            class="research-section"
            aria-labelledby={`research-archive-section-${section.id}`}
          >
            <header class="research-section__header">
              <Typography
                variant="mono"
                as="h2"
                class="research-section__title"
                id={`research-archive-section-${section.id}`}
              >
                {section.title}
              </Typography>

              <span class="content-section-count">
                {groups.reduce((sum, group) => sum + group.entries.length, 0)}
                материалов
              </span>
            </header>

            <div class="research-archive-groups">
              {groups.map(({ group, entries }) => (
                <section
                  class="research-archive-group"
                  aria-labelledby={`research-archive-group-${group.id}`}
                >
                  <header class="research-archive-group__header">
                    <Typography
                      variant="mono"
                      as="h3"
                      id={`research-archive-group-${group.id}`}
                    >
                      {group.title}
                    </Typography>
                    <span>{entries.length} материалов</span>
                  </header>

                  {entries.length > 0 ? (
                    <div class="research-articles__list">
                      {entries.map((entry, index) => {
                        const articleSlug = entry.slug.split("/").at(-1);

                        return (
                          <a
                            href={`/research/${group.id}/${articleSlug}`}
                            class="research-article-card"
                            aria-label={`Открыть материал ${entry.meta.title}`}
                          >
                            <div class="research-article-card__main">
                              <div class="research-article-card__eyebrow">
                                <Typography
                                  variant="mono"
                                  as="span"
                                  class="research-article-card__kind"
                                >
                                  {kindLabels[entry.meta.kind]}
                                </Typography>

                                <span>Запись №{index + 1}</span>
                              </div>

                              <h4 class="research-article-card__title">
                                {entry.meta.title}
                              </h4>

                              <p class="research-article-card__description">
                                {entry.meta.description}
                              </p>
                            </div>

                            <span
                              class="research-article-card__open"
                              aria-label="Открыть материал"
                            >
                              <ArrowUpRight
                                class="research-article-card__icon"
                                aria-hidden="true"
                              />
                            </span>
                          </a>
                        );
                      })}
                    </div>
                  ) : (
                    <div class="research-section__empty">
                      <Typography variant="mono" as="span">
                        Пусто
                      </Typography>
                      <p>В этой группе пока нет опубликованных материалов.</p>
                    </div>
                  )}
                </section>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </main>
</BaseLayout>
