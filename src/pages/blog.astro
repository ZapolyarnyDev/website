---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@layouts/Header.astro";
import Typography from "@components/ui/Typography.astro";
import Button from "@components/ui/Button.astro";
import BlogArticleCard from "@components/blog/BlogArticleCard.astro";
import { getContentPageModel } from "@/content-engine";
import {
  ArrowUpRight,
  BookOpenText,
  Code2,
  GraduationCap,
  NotebookPen,
  UserRound,
} from "lucide-astro";

const blog = getContentPageModel("blog");
const pageDescription =
  "Заметки о разработке, исследованиях, инструментах и процессе обучения.";
const SECTION_PREVIEW_LIMIT = 7;
const entries = blog.sections.flatMap((section) => section.entries);

const sectionIcons = {
  "book-open-text": BookOpenText,
  "code-2": Code2,
  "graduation-cap": GraduationCap,
  "notebook-pen": NotebookPen,
  "user-round": UserRound,
};
---

<BaseLayout title="Blog | ZapolyarnyDev" description={pageDescription}>
  <Header currentPath="/blog" />

  <main class="brutal-page blog-page">
    <div class="container blog-shell">
      <section class="blog-hero" aria-labelledby="blog-title">
        <div class="blog-hero__copy">
          <Typography variant="kicker" as="span">
            <span class="home-hero__kicker-content">
              <NotebookPen class="home-hero__kicker-icon" aria-hidden="true" />
              Some thoughts, facts about me :3
            </span>
          </Typography>

          <Typography variant="hero" as="h1" id="blog-title"> Блог </Typography>

          <Typography variant="lead" as="p">
            Заметки о разработке, исследованиях, инструментах и процессе
            обучения.
          </Typography>
        </div>

        <aside
          class="blog-hero__notice"
          aria-label="Навигация для сотрудничества"
        >
          <Typography variant="mono" as="span">
            Не для сотрудничества
          </Typography>

          <p>
            Здесь мои личные заметки и разборы. Если необходимо узнать опыт,
            проекты и формат работы, стоит открыть вкладку портфолио
          </p>

          <Button href="/portfolio" variant="primary">
            Портфолио
            <ArrowUpRight class="button__icon" aria-hidden="true" />
          </Button>
        </aside>
      </section>

      <section class="content-overview" aria-label="Обзор блога">
        <div class="content-overview__item">
          <span>Формат</span>
          <strong>Заметки</strong>
        </div>
        <div class="content-overview__item">
          <span>Разделов</span>
          <strong>{blog.sections.length}</strong>
        </div>
        <div class="content-overview__item">
          <span>Материалов</span>
          <strong>{entries.length}</strong>
        </div>
        <Button
          href="/blog/archive"
          variant="primary"
          class="content-overview__action content-overview__action--primary"
        >
          Архив блога
          <ArrowUpRight class="button__icon" aria-hidden="true" />
        </Button>
      </section>

      {
        blog.sections.map(({ section, entries }) => {
          const previewEntries = entries.slice(0, SECTION_PREVIEW_LIMIT);
          const hiddenCount = entries.length - previewEntries.length;
          const SectionIcon =
            section.icon && section.icon in sectionIcons
              ? sectionIcons[section.icon as keyof typeof sectionIcons]
              : NotebookPen;

          return (
            <section
              class="blog-section"
              aria-labelledby={`blog-section-${section.id}`}
            >
              <header class="blog-section__header">
                <Typography
                  variant="mono"
                  as="h2"
                  class="blog-section__title"
                  id={`blog-section-${section.id}`}
                >
                  <SectionIcon class="blog-section__icon" aria-hidden="true" />
                  {section.title}
                </Typography>

                <span class="content-section-count">
                  {entries.length} материалов
                </span>
              </header>

              {entries.length > 0 ? (
                <div class="blog-section__articles">
                  {previewEntries.map((article) => (
                    <BlogArticleCard article={article} />
                  ))}

                  {hiddenCount > 0 && (
                    <a
                      href="/blog/archive"
                      class="content-more"
                      aria-label={`Открыть ещё ${hiddenCount} материалов раздела ${section.title}`}
                    >
                      Ещё {hiddenCount} в архиве
                      <ArrowUpRight class="button__icon" aria-hidden="true" />
                    </a>
                  )}
                </div>
              ) : (
                <div class="blog-section__empty">
                  <Typography variant="mono" as="span">
                    В работе
                  </Typography>
                  <p>Материалы появятся здесь, когда их можно будет открыть.</p>
                </div>
              )}
            </section>
          );
        })
      }
    </div>
  </main>
</BaseLayout>
