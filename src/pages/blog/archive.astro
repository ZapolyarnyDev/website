---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@layouts/Header.astro";
import Button from "@components/ui/Button.astro";
import Typography from "@components/ui/Typography.astro";
import BlogArticleCard from "@components/blog/BlogArticleCard.astro";
import { getContentPageModel } from "@/content-engine";
import { ArrowLeft, NotebookPen } from "lucide-astro";

const blog = getContentPageModel("blog");
const pageDescription = "Полный архив материалов блога.";
---

<BaseLayout title="Архив блога | ZapolyarnyDev" description={pageDescription}>
  <Header currentPath="/blog" />

  <main class="brutal-page blog-page">
    <div class="container blog-shell">
      <section class="archive-hero" aria-labelledby="blog-archive-title">
        <Typography variant="kicker" as="span">
          <span class="home-hero__kicker-content">
            <NotebookPen class="home-hero__kicker-icon" aria-hidden="true" />
            full archive
          </span>
        </Typography>

        <Typography variant="hero" as="h1" id="blog-archive-title">
          Архив блога
        </Typography>

        <Typography variant="lead" as="p">
          Все опубликованные заметки, разборы и материалы по разделам.
        </Typography>

        <div class="archive-hero__actions">
          <Button href="/blog">
            <ArrowLeft class="button__icon" aria-hidden="true" />
            К блогу
          </Button>
        </div>
      </section>

      {
        blog.sections.map(({ section, entries }) => (
          <section
            class="blog-section"
            aria-labelledby={`blog-archive-section-${section.id}`}
          >
            <header class="blog-section__header">
              <Typography
                variant="mono"
                as="h2"
                class="blog-section__title"
                id={`blog-archive-section-${section.id}`}
              >
                {section.title}
              </Typography>

              <span class="content-section-count">
                {entries.length} материалов
              </span>
            </header>

            {entries.length > 0 ? (
              <div class="blog-section__articles">
                {entries.map((article) => (
                  <BlogArticleCard article={article} />
                ))}
              </div>
            ) : (
              <div class="blog-section__empty">
                <Typography variant="mono" as="span">
                  Пусто
                </Typography>
                <p>В этом разделе пока нет опубликованных материалов.</p>
              </div>
            )}
          </section>
        ))
      }
    </div>
  </main>
</BaseLayout>
