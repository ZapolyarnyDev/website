---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@layouts/Header.astro";
import Button from "@components/ui/Button.astro";
import Typography from "@components/ui/Typography.astro";
import {
  loadEntries,
  type ContentEntry,
  type ContentEntryKind,
  type ContentEntryMeta,
} from "@/content-engine";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import { ArrowLeft, ArrowRight } from "lucide-astro";

type BlogModule = {
  default: AstroComponentFactory;
  frontmatter: ContentEntryMeta;
};

interface Props {
  Content: AstroComponentFactory;
  meta: ContentEntryMeta;
  currentEntry: ContentEntry;
  prevEntry?: ContentEntry;
  nextEntry?: ContentEntry;
}

export function getStaticPaths() {
  const articleModules = import.meta.glob("../../../content/blog/**/*.mdx", {
    eager: true,
  }) as Record<string, BlogModule>;
  const entries = loadEntries("blog");

  return Object.entries(articleModules)
    .filter(([, module]) => !module.frontmatter.draft)
    .map(([path, module]) => {
      const slug = path
        .replace("../../../content/blog/", "")
        .replace(/\.mdx$/, "")
        .replace(/\/index$/, "");
      const entryIndex = entries.findIndex((entry) => entry.slug === slug);
      const currentEntry = entries[entryIndex];

      if (!currentEntry) {
        return null;
      }

      return {
        params: { slug },
        props: {
          Content: module.default,
          meta: module.frontmatter,
          currentEntry,
          prevEntry: entryIndex > 0 ? entries[entryIndex - 1] : undefined,
          nextEntry:
            entryIndex < entries.length - 1
              ? entries[entryIndex + 1]
              : undefined,
        },
      };
    })
    .filter((path): path is Exclude<typeof path, null> => path !== null);
}

const { Content, meta, currentEntry, prevEntry, nextEntry } = Astro.props;
const blogEntries = loadEntries("blog");
const tags = meta.tags ?? [];
const currentNumber =
  blogEntries.findIndex((entry) => entry.slug === currentEntry.slug) + 1;
const entryCount = blogEntries.length;
const kindLabels: Record<ContentEntryKind, string> = {
  article: "Статья",
  note: "Заметка",
  case: "Материал",
  project: "Материал",
};

const formattedDate = meta.date
  ? new Intl.DateTimeFormat("ru-RU", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    }).format(new Date(`${meta.date}T00:00:00`))
  : null;
const titleLength = meta.title.length;
const titleSizeClass =
  titleLength > 52
    ? "blog-post__title--very-long"
    : titleLength > 34
      ? "blog-post__title--long"
      : "";
---

<BaseLayout
  title={`${meta.title} | Блог ZapolyarnyDev`}
  description={meta.description}
  ogType="article"
>
  <Header currentPath="/blog" />

  <main class="brutal-page blog-post-page">
    <article class="container blog-post">
      <header class="blog-post__header">
        <div class="blog-post__copy">
          <Typography variant="kicker" as="span">
            {kindLabels[meta.kind]}
          </Typography>

          <Typography
            variant="hero"
            as="h1"
            class={`blog-post__title ${titleSizeClass}`}
          >
            {meta.title}
          </Typography>

          <Typography variant="lead" as="p">
            {meta.description}
          </Typography>
        </div>

        <aside class="blog-post__meta" aria-label="Данные материала">
          {meta.date && formattedDate && <span>Дата</span>}
          {
            meta.date && formattedDate && (
              <time datetime={meta.date}>{formattedDate}</time>
            )
          }

          {tags.length > 0 && <span>Теги</span>}

          {
            tags.length > 0 && (
              <ul>
                {tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            )
          }
        </aside>
      </header>

      <div class="blog-post__back">
        <Button href="/blog">
          <ArrowLeft class="button__icon" aria-hidden="true" />
          Вернуться в блог
        </Button>
      </div>

      <div class="blog-post__content markdown-content">
        <Content />
      </div>

      <nav class="article-sequence-nav" aria-label="Навигация по заметкам">
        {
          prevEntry ? (
            <a
              href={`/blog/${prevEntry.slug}`}
              class="article-sequence-nav__link"
            >
              <ArrowLeft aria-hidden="true" />
              <span>Предыдущая</span>
              <strong>{prevEntry.meta.title}</strong>
            </a>
          ) : (
            <span class="article-sequence-nav__link article-sequence-nav__link--disabled">
              <ArrowLeft aria-hidden="true" />
              <span>Начало</span>
              <strong>Предыдущей заметки нет</strong>
            </span>
          )
        }

        <div class="article-sequence-nav__current">
          Заметка {currentNumber} из {entryCount}
        </div>

        {
          nextEntry ? (
            <a
              href={`/blog/${nextEntry.slug}`}
              class="article-sequence-nav__link article-sequence-nav__link--next"
            >
              <span>Следующая</span>
              <strong>{nextEntry.meta.title}</strong>
              <ArrowRight aria-hidden="true" />
            </a>
          ) : (
            <span class="article-sequence-nav__link article-sequence-nav__link--disabled article-sequence-nav__link--next">
              <span>Конец</span>
              <strong>Следующей заметки нет</strong>
              <ArrowRight aria-hidden="true" />
            </span>
          )
        }
      </nav>
    </article>
  </main>
</BaseLayout>
