---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@layouts/Header.astro";
import Typography from "@components/ui/Typography.astro";
import Button from "@components/ui/Button.astro";
import PortfolioGroupCard from "@components/portfolio/PortfolioGroupCard.astro";
import PortfolioProjectCard from "@components/portfolio/PortfolioProjectCard.astro";
import { getContentPageModel } from "@/content-engine";
import {
  ArrowUpRight,
  BriefcaseBusiness,
  Code2,
  Gamepad2,
  Handshake,
  ListChecks,
} from "lucide-astro";

const portfolio = getContentPageModel("portfolio");
const pageDescription =
  "Портфолио ZapolyarnyDev: текущие проекты, результаты и материалы для сотрудничества.";
const SECTION_PREVIEW_LIMIT = 5;
const directProjects = portfolio.sections.flatMap((section) => section.entries);
const groupedProjects = portfolio.sections.flatMap((section) =>
  section.groups.flatMap((group) => group.entries),
);
const projects = [...directProjects, ...groupedProjects];
const featuredCount = projects.filter(
  (project) => project.meta.featured,
).length;
const featuredProjects = projects.filter((project) => project.meta.featured);
const portfolioSections = portfolio.sections
  .map(({ section, groups, entries }) => ({
    section,
    groups,
    entries: entries.filter((project) => !project.meta.featured),
  }))
  .filter(({ groups, entries }) => groups.length > 0 || entries.length > 0);
const casesAnchorOnFeatured = featuredProjects.length > 0;

const sectionIcons = {
  "briefcase-business": BriefcaseBusiness,
  "code-2": Code2,
  "gamepad-2": Gamepad2,
};
---

<BaseLayout
  title="Портфолио Java и Minecraft разработчика | ZapolyarnyDev"
  description={pageDescription}
>
  <Header currentPath="/portfolio" />

  <main class="brutal-page portfolio-page">
    <div class="container portfolio-shell">
      <section class="portfolio-hero" aria-labelledby="portfolio-title">
        <Typography variant="kicker" as="span">
          <span class="home-hero__kicker-content">
            <BriefcaseBusiness
              class="home-hero__kicker-icon"
              aria-hidden="true"
            />
            cooperation
          </span>
        </Typography>

        <Typography variant="hero" as="h1" id="portfolio-title">
          Портфолио
        </Typography>

        <Typography variant="lead" as="p">
          Коммерческий и практический опыт: что делал, в каком контексте, какой
          стек использовал и какие навыки у меня есть.
        </Typography>
      </section>

      <section class="content-overview" aria-label="Обзор портфолио">
        <div class="content-overview__item">
          <span>Фокус</span>
          <strong>Инженерия</strong>
        </div>
        <div class="content-overview__item">
          <span>Кейсов</span>
          <strong>{projects.length}</strong>
        </div>
        <div class="content-overview__item">
          <span>Ключевых</span>
          <strong>{featuredCount}</strong>
        </div>
        <Button
          href="/portfolio/archive"
          variant="primary"
          class="content-overview__action content-overview__action--primary"
        >
          Архив проектов
          <ArrowUpRight class="button__icon" aria-hidden="true" />
        </Button>
      </section>

      <section class="portfolio-client-strip" aria-label="Что смотреть клиенту">
        <div class="portfolio-client-strip__item">
          <Handshake aria-hidden="true" />
          <span>Для сотрудничества</span>
          <strong>Быстро рассмотреть мой опыт</strong>
        </div>

        <div class="portfolio-client-strip__item">
          <ListChecks aria-hidden="true" />
          <span>Внутри кейсов</span>
          <strong>Роль, стек и результат</strong>
        </div>
      </section>

      {
        featuredProjects.length > 0 && (
          <section
            class="portfolio-section portfolio-section--featured"
            id="portfolio-cases"
            aria-labelledby="portfolio-featured"
          >
            <header class="portfolio-section__header">
              <Typography
                variant="mono"
                as="h2"
                class="portfolio-section__title"
                id="portfolio-featured"
              >
                <BriefcaseBusiness
                  class="portfolio-section__icon"
                  aria-hidden="true"
                />
                Ключевые кейсы
              </Typography>
            </header>

            <div class="portfolio-section__projects">
              {featuredProjects.map((project) => (
                <PortfolioProjectCard project={project} />
              ))}
            </div>
          </section>
        )
      }

      {
        portfolioSections.map(({ section, groups, entries }, index) => {
          const visibleItems = [
            ...groups.map((group) => ({ type: "group" as const, group })),
            ...entries.map((entry) => ({ type: "entry" as const, entry })),
          ];
          const previewItems = visibleItems.slice(0, SECTION_PREVIEW_LIMIT);
          const hiddenCount = visibleItems.length - previewItems.length;
          const SectionIcon =
            section.icon && section.icon in sectionIcons
              ? sectionIcons[section.icon as keyof typeof sectionIcons]
              : BriefcaseBusiness;

          return (
            <section
              class="portfolio-section"
              id={
                !casesAnchorOnFeatured && index === 0
                  ? "portfolio-cases"
                  : undefined
              }
              aria-labelledby={`portfolio-section-${section.id}`}
            >
              <header class="portfolio-section__header">
                <Typography
                  variant="mono"
                  as="h2"
                  class="portfolio-section__title"
                  id={`portfolio-section-${section.id}`}
                >
                  <SectionIcon
                    class="portfolio-section__icon"
                    aria-hidden="true"
                  />
                  {section.title}
                </Typography>

                <span class="content-section-count">
                  {visibleItems.length} материалов
                </span>
              </header>

              {visibleItems.length > 0 ? (
                <div class="portfolio-section__projects">
                  {previewItems.map((item) =>
                    item.type === "group" ? (
                      <PortfolioGroupCard model={item.group} />
                    ) : (
                      <PortfolioProjectCard
                        project={item.entry}
                        sectionTitle={section.title}
                      />
                    ),
                  )}

                  {hiddenCount > 0 && (
                    <a
                      href="/portfolio/archive"
                      class="content-more"
                      aria-label={`Открыть ещё ${hiddenCount} проектов раздела ${section.title}`}
                    >
                      Ещё {hiddenCount} в архиве
                      <ArrowUpRight class="button__icon" aria-hidden="true" />
                    </a>
                  )}
                </div>
              ) : (
                <div class="portfolio-section__empty">
                  <Typography variant="mono" as="span">
                    В разработке
                  </Typography>
                  <p>
                    Проекты появятся здесь, когда их можно будет показать
                    нормально: с контекстом, результатом и материалами.
                  </p>
                </div>
              )}
            </section>
          );
        })
      }
    </div>
  </main>
</BaseLayout>
