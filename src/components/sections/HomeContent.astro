---
import { ArrowUpRight } from "lucide-astro";

import HomeWorkCard from "@components/home/HomeWorkCard.astro";
import Button from "@components/ui/Button.astro";
import Typography from "@components/ui/Typography.astro";
import { getContentPageModel } from "@/content-engine";

const portfolio = getContentPageModel("portfolio");
const portfolioEntries = portfolio.sections.flatMap(({ entries, groups }) => [
  ...entries,
  ...groups.flatMap((group) => group.entries),
]);
const cristalix = portfolio.sections
  .flatMap(({ groups }) => groups)
  .find(({ group }) => group.id === "cristalix");
const selectedProjects = ["proxyvirtualizer", "medical-appointment"]
  .map((slug) => portfolioEntries.find((entry) => entry.slug === slug))
  .filter((entry) => entry !== undefined);
---

<div class="home-content">
  <section class="container home-section" aria-labelledby="featured-projects">
    <header class="home-section__header">
      <div>
        <Typography variant="kicker" as="span">избранное</Typography>
        <Typography variant="hero" as="h2" id="featured-projects">
          Проекты
        </Typography>
      </div>

      <Button href="/portfolio">
        Все проекты <ArrowUpRight class="button__icon" aria-hidden="true" />
      </Button>
    </header>

    <div class="home-works-grid">
      {
        cristalix && (
          <HomeWorkCard
            href={`/portfolio/${cristalix.group.id}`}
            label="Cristalix / кейс"
            title="Игровые режимы"
            description={cristalix.group.description ?? ""}
            tags={["Minecraft", "Gamedev"]}
          />
        )
      }

      {
        selectedProjects.map((project) => (
          <HomeWorkCard
            href={`/portfolio/${project.slug}`}
            label="Проект"
            title={project.meta.title}
            description={project.meta.description}
            tags={project.meta.tags?.slice(0, 3)}
          />
        ))
      }
    </div>
  </section>
</div>
