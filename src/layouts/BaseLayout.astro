---
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ZapolyarnyDev",
  description = "Personal website of ZapolyarnyDev",
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <meta name="color-scheme" content="light" />

    <title>{title}</title>

    <link
      rel="preload"
      href="/fonts/manrope-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/jetbrains-mono-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>

  <body>
    <slot />
  </body>
</html>
