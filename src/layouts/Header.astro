---
import NavButton from "@components/ui/NavButton.astro";
import { Menu, X, Sun, Moon } from "lucide-astro";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const links = [
  {
    href: "/",
    label: "Главная",
    icon: "home",
  },
  {
    href: "/blog",
    label: "Блог",
    icon: "notebook-pen",
  },
  {
    href: "/portfolio",
    label: "Портфолио",
    icon: "briefcase-business",
  },
  {
    href: "/research",
    label: "Исследования",
    icon: "flask-conical",
  },
] as const;
---

<header class="header">
  <div class="container header__inner">
    <a class="header__brand" href="/">
      <img
        class="header__brand-mark"
        src="/logo-universal.png?v=4"
        width="974"
        height="974"
        alt=""
      />

      <span> ZapolyarnyDev </span>
    </a>

    <nav class="header__nav">
      {
        links.map((link) => (
          <NavButton
            href={link.href}
            icon={link.icon}
            active={currentPath === link.href}
          >
            {link.label}
          </NavButton>
        ))
      }
    </nav>

    <div class="header__actions">
      <div class="header__accent-picker" data-accent-picker>
        <button
          class="header__accent-trigger"
          type="button"
          aria-label="Выбрать цвет интерфейса"
          aria-expanded="false"
          aria-controls="accent-options"
          data-accent-trigger
        >
          <span class="header__accent-swatch" data-accent-swatch></span>
          <span class="header__accent-label" data-accent-label>Выбор цвета</span
          >
        </button>

        <div
          class="header__accent-menu"
          id="accent-options"
          role="menu"
          aria-label="Цвет интерфейса"
          hidden
          data-accent-menu
        >
          <button
            class="header__accent-option"
            type="button"
            role="menuitemradio"
            aria-checked="true"
            data-accent-option="polar-signal"
          >
            <span
              class="header__accent-swatch header__accent-swatch--polar-signal"
            ></span>
            <span>Сигнал Заполярья</span>
          </button>
          <button
            class="header__accent-option"
            type="button"
            role="menuitemradio"
            aria-checked="false"
            data-accent-option="icy-impulse"
          >
            <span
              class="header__accent-swatch header__accent-swatch--icy-impulse"
            ></span>
            <span>Ледяной импульс</span>
          </button>
          <button
            class="header__accent-option"
            type="button"
            role="menuitemradio"
            aria-checked="false"
            data-accent-option="cold-pine"
          >
            <span class="header__accent-swatch header__accent-swatch--cold-pine"
            ></span>
            <span>Холодная хвоя</span>
          </button>
          <button
            class="header__accent-option"
            type="button"
            role="menuitemradio"
            aria-checked="false"
            data-accent-option="northern-glow"
          >
            <span
              class="header__accent-swatch header__accent-swatch--northern-glow"
            ></span>
            <span>Северное свечение</span>
          </button>
          <button
            class="header__accent-option"
            type="button"
            role="menuitemradio"
            aria-checked="false"
            data-accent-option="amber-pole"
          >
            <span
              class="header__accent-swatch header__accent-swatch--amber-pole"
            ></span>
            <span>Янтарный полюс</span>
          </button>
        </div>
      </div>

      <button
        class="header__theme-toggle"
        type="button"
        aria-label="Переключить тему"
        data-theme-toggle
      >
        <Sun
          class="header__theme-icon header__theme-icon--sun"
          aria-hidden="true"
        />
        <Moon
          class="header__theme-icon header__theme-icon--moon"
          aria-hidden="true"
        />
      </button>

      <button
        class="header__menu-toggle"
        type="button"
        aria-label="Открыть меню"
        aria-expanded="false"
        aria-controls="mobile-navigation"
        data-menu-toggle
      >
        <Menu
          class="header__menu-icon header__menu-icon--open"
          aria-hidden="true"
        />
        <X
          class="header__menu-icon header__menu-icon--close"
          aria-hidden="true"
        />
      </button>
    </div>
  </div>
</header>

<div
  class="mobile-menu"
  id="mobile-navigation"
  aria-hidden="true"
  data-mobile-menu
>
  <div class="container mobile-menu__inner">
    <div class="mobile-menu__top">
      <span class="mobile-menu__title">Меню</span>

      <button
        class="mobile-menu__close"
        type="button"
        aria-label="Закрыть меню"
        data-menu-close
      >
        <X class="header__menu-icon" aria-hidden="true" />
      </button>
    </div>

    <nav class="mobile-menu__nav" aria-label="Мобильная навигация">
      {
        links.map((link) => (
          <NavButton
            href={link.href}
            icon={link.icon}
            active={currentPath === link.href}
            class="mobile-menu__link"
          >
            {link.label}
          </NavButton>
        ))
      }
    </nav>
  </div>
</div>

<script>
  const themeToggle = document.querySelector("[data-theme-toggle]");
  const root = document.documentElement;

  const persistPreference = (key: string, value: string) => {
    try {
      localStorage.setItem(key, value);
      return true;
    } catch {
      return false;
    }
  };

  const syncThemeButton = () => {
    if (!(themeToggle instanceof HTMLButtonElement)) return;
    const isDark = root.dataset.theme === "dark";
    themeToggle.setAttribute(
      "aria-label",
      isDark ? "Включить светлую тему" : "Включить тёмную тему",
    );
  };

  syncThemeButton();

  themeToggle?.addEventListener("click", () => {
    const next = root.dataset.theme === "dark" ? "light" : "dark";
    root.dataset.theme = next;
    persistPreference("theme", next);
    syncThemeButton();
  });

  const accentPicker = document.querySelector("[data-accent-picker]");
  const accentTrigger = document.querySelector("[data-accent-trigger]");
  const accentMenu = document.querySelector("[data-accent-menu]");
  const accentSwatch = document.querySelector("[data-accent-swatch]");
  const accentLabel = document.querySelector("[data-accent-label]");
  const accentOptions = document.querySelectorAll("[data-accent-option]");

  const accentNames: Record<string, string> = {
    "polar-signal": "Сигнал Заполярья",
    "icy-impulse": "Ледяной импульс",
    "cold-pine": "Холодная хвоя",
    "northern-glow": "Северное свечение",
    "amber-pole": "Янтарный полюс",
  };

  const syncAccentPicker = () => {
    const accent = root.dataset.accent ?? "polar-signal";

    if (accentTrigger instanceof HTMLButtonElement) {
      accentTrigger.dataset.accent = accent;
      accentTrigger.setAttribute("aria-label", "Выбор цвета интерфейса");
    }

    if (accentSwatch instanceof HTMLElement) {
      accentSwatch.dataset.accent = accent;
    }

    if (accentLabel instanceof HTMLElement) {
      accentLabel.textContent = "Выбор цвета";
    }

    accentOptions.forEach((option) => {
      option.setAttribute(
        "aria-checked",
        String(option.getAttribute("data-accent-option") === accent),
      );
    });
  };

  const setAccentMenuOpen = (isOpen: boolean) => {
    if (
      !(accentTrigger instanceof HTMLButtonElement) ||
      !(accentMenu instanceof HTMLElement)
    ) {
      return;
    }

    accentTrigger.setAttribute("aria-expanded", String(isOpen));
    accentMenu.hidden = !isOpen;
  };

  syncAccentPicker();

  accentTrigger?.addEventListener("click", () => {
    const isOpen = accentTrigger.getAttribute("aria-expanded") === "true";
    setAccentMenuOpen(!isOpen);
  });

  accentOptions.forEach((option) => {
    option.addEventListener("click", () => {
      const accent = option.getAttribute("data-accent-option");
      if (!accent || !(accent in accentNames)) return;

      root.dataset.accent = accent;
      persistPreference("accent", accent);
      syncAccentPicker();
      setAccentMenuOpen(false);
      if (accentTrigger instanceof HTMLButtonElement) {
        accentTrigger.focus();
      }
    });
  });

  document.addEventListener("click", (event) => {
    if (
      accentPicker instanceof HTMLElement &&
      event.target instanceof Node &&
      !accentPicker.contains(event.target)
    ) {
      setAccentMenuOpen(false);
    }
  });

  const toggle = document.querySelector("[data-menu-toggle]");
  const closeButton = document.querySelector("[data-menu-close]");
  const menu = document.querySelector("[data-mobile-menu]");
  const links = menu?.querySelectorAll("a") ?? [];
  let lastFocused: HTMLElement | null = null;

  const focusableSelector =
    'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

  const getFocusable = (): HTMLElement[] => {
    if (!menu) return [];
    return Array.from(
      menu.querySelectorAll<HTMLElement>(focusableSelector),
    ).filter((el) => el.offsetParent !== null || el === closeButton);
  };

  const setMenuOpen = (isOpen: boolean) => {
    if (
      !(toggle instanceof HTMLButtonElement) ||
      !(menu instanceof HTMLElement)
    ) {
      return;
    }

    toggle.setAttribute("aria-expanded", String(isOpen));
    toggle.setAttribute("aria-label", isOpen ? "Закрыть меню" : "Открыть меню");
    menu.setAttribute("aria-hidden", String(!isOpen));
    menu.toggleAttribute("data-open", isOpen);
    document.body.classList.toggle("menu-open", isOpen);

    if (isOpen) {
      lastFocused = document.activeElement as HTMLElement;

      window.setTimeout(() => {
        const first = getFocusable()[0];
        first?.focus();
      }, 60);
    } else {
      lastFocused?.focus();
      lastFocused = null;
    }
  };

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    setMenuOpen(!isOpen);
  });

  closeButton?.addEventListener("click", () => setMenuOpen(false));

  links.forEach((link) => {
    link.addEventListener("click", () => setMenuOpen(false));
  });

  menu?.addEventListener("keydown", (event) => {
    const keyboardEvent = event as KeyboardEvent;
    if (keyboardEvent.key !== "Tab") return;
    const focusable = getFocusable();
    if (focusable.length === 0) return;

    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    const active = document.activeElement as HTMLElement;

    if (keyboardEvent.shiftKey) {
      if (active === first || !menu?.contains(active)) {
        keyboardEvent.preventDefault();
        last.focus();
      }
    } else {
      if (active === last) {
        keyboardEvent.preventDefault();
        first.focus();
      }
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setAccentMenuOpen(false);
      setMenuOpen(false);
    }
  });

  const desktopQuery = window.matchMedia("(min-width: 1241px)");
  desktopQuery.addEventListener("change", (event) => {
    if (event.matches) setMenuOpen(false);
  });
</script>
